{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@naveencodes/ai": ["packages/ai/src/index.ts"],
      "@naveencodes/auth": ["packages/auth/src/index.ts"],
      "@naveencodes/core": ["packages/core/src/index.ts"],
      "@naveencodes/mcp": ["packages/mcp/src/index.ts"],
      "@naveencodes/reports": ["packages/reports/src/index.ts"]
    }
  }
}
