NODE_ENV=production
PORT=4000
APP_URL=https://server.naveencodes.com
FRONTEND_BASE_URL=https://ai.naveencodes.com
BACKEND_BASE_URL=https://server.naveencodes.com
CORS_ALLOWED_ORIGINS=https://ai.naveencodes.com
NEXT_PUBLIC_API_URL=https://server.naveencodes.com

JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_SECRET=replace-with-a-long-random-encryption-secret

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=replace_me
DB_USER=replace_me
DB_PASSWORD=replace_me
DB_CONNECTION_LIMIT=10
DB_SSL=false

REDIS_URL=redis://127.0.0.1:6379

AI_PROVIDER=openai
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_MODEL=gpt-4.1-mini
AI_REQUEST_TIMEOUT_MS=60000
AI_SYSTEM_PROMPT=You are a senior AI software engineer. Give concise, production-focused analysis and remediation steps.

MCP_BROWSER_URL=http://127.0.0.1:9222
MCP_SERVER_COMMAND=node
MCP_SERVER_ARGS=/opt/naveencodes/chrome-devtools-mcp/build/src/bin/chrome-devtools-mcp.js,--headless,--browser-url=http://127.0.0.1:9222
CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome
CHROME_REMOTE_DEBUGGING_PORT=9222
CHROME_HEADLESS=true
CHROME_USER_DATA_DIR=/opt/naveencodes/runtime/chrome-profile
CHROME_STARTUP_TIMEOUT_MS=30000
CHROME_EXTRA_ARGS=--disable-dev-shm-usage,--no-first-run,--no-default-browser-check,--remote-debugging-address=127.0.0.1

QA_MAX_PARALLEL_SESSIONS=3
APP_LOG_FILE=/opt/naveencodes/logs/runtime.jsonl
QA_DEFAULT_TARGET_URL=https://ai.naveencodes.com
QA_LOAD_TEST_USERS=25
QA_AUTO_FIX_SAFE_MODE=balanced

PREVIEW_BASE_DOMAIN=preview.naveencodes.dev
PRODUCTION_BASE_DOMAIN=naveencodes.com
VERCEL_TEAM_SLUG=naveencodes
GITHUB_REPO_URL=https://github.com/naveengoyal1503/Naveencodes-AI-Dev-OS
GITHUB_DEFAULT_BRANCH=main

PAYMENT_PROVIDER=stripe
STRIPE_PUBLIC_KEY=pk_live_replace_me
STRIPE_SECRET_KEY=sk_live_replace_me
ALERT_WEBHOOK_URL=https://hooks.example.com/naveencodes-ai

SERVE_FRONTEND_STATIC=false
FRONTEND_STATIC_DIR=apps/frontend/out
