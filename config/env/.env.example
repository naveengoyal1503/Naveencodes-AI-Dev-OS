NODE_ENV=development
PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
APP_URL=http://localhost:3000
JWT_SECRET=change-me
DATABASE_URL=postgres://postgres:postgres@localhost:5432/naveencodes_ai
REDIS_URL=redis://localhost:6379
MCP_BROWSER_URL=http://127.0.0.1:9222
MCP_SERVER_COMMAND=npx
MCP_SERVER_ARGS=-y,chrome-devtools-mcp@0.20.3,--headless,--browser-url=http://127.0.0.1:9222
CHROME_EXECUTABLE_PATH=
CHROME_REMOTE_DEBUGGING_PORT=9222
CHROME_HEADLESS=true
CHROME_USER_DATA_DIR=.runtime/chrome-profile
CHROME_STARTUP_TIMEOUT_MS=30000
CHROME_EXTRA_ARGS=
QA_MAX_PARALLEL_SESSIONS=3
APP_LOG_FILE=logs/runtime.jsonl
QA_DEFAULT_TARGET_URL=http://localhost:3000
QA_LOAD_TEST_USERS=25
QA_AUTO_FIX_SAFE_MODE=balanced
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:4000
PREVIEW_BASE_DOMAIN=preview.naveencodes.dev
PRODUCTION_BASE_DOMAIN=app.naveencodes.dev
VERCEL_TEAM_SLUG=naveencodes
GITHUB_REPO_URL=https://github.com/naveengoyal1503/Naveencodes-AI-Dev-OS
GITHUB_DEFAULT_BRANCH=main
PAYMENT_PROVIDER=stripe
STRIPE_PUBLIC_KEY=pk_test_change_me
STRIPE_SECRET_KEY=sk_test_change_me
ALERT_WEBHOOK_URL=https://hooks.example.com/naveencodes-ai
SERVE_FRONTEND_STATIC=false
FRONTEND_STATIC_DIR=apps/frontend/out
